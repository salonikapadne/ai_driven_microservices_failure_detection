# .env.example — copy to .env and fill in your values
#
# LLM Provider selection
# Options: vertex_ai | gemini | openai | local (Ollama)
LLM_PROVIDER=local
LLM_FALLBACKS=gemini,openai

# Ollama (local — no API key needed)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b

# Google Gemini (direct API)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Vertex AI
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Set to "true" to simulate Docker commands without executing them
DRY_RUN=false

# hil-db-demo — timed demo: benign heartbeats, then HIL escalation (see hil-db-demo/demo-log.sh)
HIL_ESCALATE_AFTER_SEC=60
HIL_DUMMY_INTERVAL_SEC=10
HIL_DEMO_INTERVAL_SEC=120

# RabbitMQ consumer
# URL format: amqp://<user>:<pass>@<host>:<port>/
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE=logs_queue
# Set to "true" to disable the background consumer (HTTP-only / test mode)
DISABLE_CONSUMER=false

# Dashboard — stream ai_engine (agent/state/tools) logs to the React UI via Socket.IO
AI_ENGINE_LOG_TO_UI=true
# Max lines kept server-side for reconnect / initial_state (default 300)
MAX_AI_ENGINE_LOGS=300
# Python log level for those loggers (INFO, DEBUG, WARNING, ...)
LOG_LEVEL=INFO

# Email alerts — recipients: comma-separated; merged with dashboard UI list.
# Only define each variable once (duplicate keys in .env override earlier lines).
EMAIL_ALERT_RECIPIENTS=ops@example.com,oncall@example.com
#
# Resend: https://resend.com — API key + From address.
# With onboarding@resend.dev, Resend only delivers TO your Resend account email until you verify a domain
# (https://resend.com/domains) and set RESEND_FROM to an address on that domain.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=MicroMonitor <onboarding@resend.dev>
#
# Optional fallback: Gmail SMTP via nodemailer (App Password if 2FA on). Ignored if RESEND_API_KEY and RESEND_FROM are set.
EMAIL_USER=
EMAIL_PASS=
#
# Mail sidecar: dashboard POSTs here when MAILER_URL is set (Python smtplib used only if MAILER_URL is unset).
MAILER_URL=http://mail-service:4100
MAILER_INTERNAL_TOKEN=change-me-to-a-long-random-string

# Frontend (Vite) — Socket.IO URL for the dashboard (passed to frontend service in docker-compose)
# Use http://localhost:4000 when the browser runs on the same machine as Docker.
# From another device, use http://<host-LAN-IP>:4000
VITE_SOCKET_URL=http://localhost:4000

# Code-heal demo (buggy-service): ai-engine reads/writes live app under CODE_HEAL_ROOT; verify via HTTP after fix.
# Host path is mounted at /buggy-live in ai-engine (see docker-compose). Restart buggy-service resets seed→live in the container.
CODE_HEAL_ROOT=/buggy-live
CODE_HEAL_FILES=app.py
CODE_HEAL_SERVICES=buggy-service
BUGGY_SERVICE_HEALTH_URL=http://buggy-service:3010/health
