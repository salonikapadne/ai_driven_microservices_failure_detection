# .env.example — copy to .env and fill in your values
#
# LLM Provider selection
# Options: vertex_ai | gemini | openai | local (Ollama)
LLM_PROVIDER=local
LLM_FALLBACKS=gemini,openai

# Ollama (local — no API key needed)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b

# Google Gemini (direct API)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Vertex AI
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Set to "true" to simulate Docker commands without executing them
DRY_RUN=false

# RabbitMQ consumer
# URL format: amqp://<user>:<pass>@<host>:<port>/
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE=logs_queue
# Set to "true" to disable the background consumer (HTTP-only / test mode)
DISABLE_CONSUMER=false

# Dashboard — stream ai_engine (agent/state/tools) logs to the React UI via Socket.IO
AI_ENGINE_LOG_TO_UI=true
# Max lines kept server-side for reconnect / initial_state (default 300)
MAX_AI_ENGINE_LOGS=300
# Python log level for those loggers (INFO, DEBUG, WARNING, ...)
LOG_LEVEL=INFO

# Frontend (Vite) — Socket.IO URL for the dashboard (passed to frontend service in docker-compose)
# Use http://localhost:4000 when the browser runs on the same machine as Docker.
# From another device, use http://<host-LAN-IP>:4000
VITE_SOCKET_URL=http://localhost:4000
